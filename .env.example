# Copiar a .env en esta carpeta (qwerys-project/) y rellenar.
# .env está en .gitignore — no subir al repositorio.
# Las API keys NO van en la imagen Docker; solo aquí al arrancar compose.

MYSQL_ROOT_PASSWORD=qwerys2024
MYSQL_DATABASE=qwerys
POSTGRES_PASSWORD=root

# Mínimo 32 caracteres (JWT)
JWT_SECRET=texto del tamaño de-32-characters

# IA (opcional — sin key sigue el mentor por reglas)
AI_API_KEY=
# Sin OpenRouter en esta entrega:
# AI_FALLBACK_API_KEY=
